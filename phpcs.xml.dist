<?xml version="1.0"?>
<ruleset name="DB Cookie Manager">
	<description>Standard di codifica per DB Cookie Manager (WordPress, calibrato sulle convenzioni della DB suite).</description>

	<file>.</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>

	<arg value="ps"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>

	<rule ref="WordPress">
		<!-- ============================================================
		     STILE — esclusioni estetiche (nessun impatto su correttezza).
		     ============================================================ -->
		<exclude name="Generic.ControlStructures.DisallowYodaConditions"/>
		<exclude name="WordPress.PHP.YodaConditions.NotYoda"/>

		<!-- Naming file: la DB suite usa 'class-<nome>.php'. -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>

		<!-- Stile commenti / doc-block. -->
		<exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
		<exclude name="Squiz.Commenting.InlineComment.NotCapital"/>
		<exclude name="Squiz.Commenting.BlockComment.CloserSameLine"/>
		<exclude name="Squiz.Commenting.BlockComment.NoNewLine"/>
		<exclude name="Squiz.Commenting.BlockComment.SingleLine"/>
		<exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
		<exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
		<exclude name="Squiz.Commenting.FunctionComment.Missing"/>
		<exclude name="Squiz.Commenting.FunctionComment.MissingParamComment"/>
		<exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
		<exclude name="Squiz.Commenting.ClassComment.Missing"/>
		<exclude name="Squiz.Commenting.VariableComment.Missing"/>
		<exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>
		<exclude name="Generic.Commenting.DocComment.MissingShort"/>
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
		<exclude name="Universal.Operators.DisallowShortTernary.Found"/>
		<exclude name="Squiz.PHP.DisallowSizeFunctionsInLoops.Found"/>
		<exclude name="Generic.CodeAnalysis.UnusedFunctionParameter"/>
		<exclude name="WordPress.Arrays.MultipleStatementAlignment.DoubleArrowNotAligned"/>

		<!-- Parola riservata come nome parametro (es. $new in replace_all):
		     ammessa, non causa problemi con $this->$new. -->
		<exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames.newFound"/>

		<!-- Variabili "globali" in file top-level senza wrapper (uninstall.php). -->
		<exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>

		<!-- Prefissi: DB_GitHub_Updater è una classe CONDIVISA tra i plugin
		     della DB suite (stesso file identico in ognuno). Il prefisso 'DB_'
		     è < 4 caratteri, quindi WPCS lo rifiuta, ma rinominarla romperebbe
		     la condivisione. Lo sniff è escluso SOLO per il file dell'updater. -->

		<!-- ============================================================
		     SICUREZZA — FALSI POSITIVI VERIFICATI MANUALMENTE (rev. 3.3.0).
		     SQL sempre via $wpdb->prepare() con placeholder; nomi tabella
		     interni. Input $_SERVER/$_COOKIE sempre unslashed + validati.
		     Nessun problema nonce/CSRF. NON riattivare senza nuova revisione.
		     ============================================================ -->
		<exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
		<exclude name="WordPress.Security.ValidatedSanitizedInput.InputNotSanitized"/>
		<exclude name="WordPress.Security.ValidatedSanitizedInput.MissingUnslash"/>
	</rule>

	<config name="text_domain" value="db-cookie-manager"/>

	<!-- Prefissi validi (>= 4 char) del plugin. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="dbcm"/>
				<element value="DBCM"/>
			</property>
		</properties>
	</rule>

	<!-- L'updater condiviso 'DB_GitHub_Updater' (prefisso DB_ deliberato,
	     riusato in tutta la suite): esente dal controllo prefissi. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals.ShortPrefixPassed">
		<exclude-pattern>*/class-updater.php</exclude-pattern>
	</rule>
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedClassFound">
		<exclude-pattern>*/class-updater.php</exclude-pattern>
	</rule>

	<!-- Query dirette e schema change legittimi su tabelle PROPRIE del plugin:
	     uninstall.php (cancellazione), class-consent-log.php e class-scanner.php
	     (CRUD su tabelle di log/risultati che cambiano di continuo — il caching
	     non è applicabile). -->
	<rule ref="WordPress.DB.DirectDatabaseQuery">
		<exclude-pattern>*/uninstall.php</exclude-pattern>
		<exclude-pattern>*/class-consent-log.php</exclude-pattern>
		<exclude-pattern>*/class-scanner.php</exclude-pattern>
	</rule>

	<!-- Export CSV in streaming verso php://output (fopen/fputcsv/fclose +
	     exit): è il modo corretto di generare un download HTTP. WP_Filesystem
	     serve a scrivere file su disco, non ad emettere una risposta: qui non
	     si applica. Falso positivo su class-consent-log.php. -->
	<rule ref="WordPress.WP.AlternativeFunctions.file_system_operations_fwrite">
		<exclude-pattern>*/class-consent-log.php</exclude-pattern>
	</rule>
	<rule ref="WordPress.WP.AlternativeFunctions.file_system_operations_fclose">
		<exclude-pattern>*/class-consent-log.php</exclude-pattern>
	</rule>
	<rule ref="WordPress.WP.AlternativeFunctions.file_system_operations_fopen">
		<exclude-pattern>*/class-consent-log.php</exclude-pattern>
	</rule>

	<!-- "50% valid code": docblock che descrive la detection User-Agent e
	     contiene stringhe tipo "Chrome" tra virgolette, scambiato per codice
	     commentato. Falso positivo. Stesso caso in class-admin.php (commenti
	     inline dopo valori numerici, es. posizione menu "81 // ...").
	     3.5.1: class-admin.php è stato spezzato in class-admin-page-*.php
	     (refactor meccanico, codice identico) → pattern esteso a coprire
	     i file estratti, stessa verifica manuale. -->
	<rule ref="Squiz.PHP.CommentedOutCode">
		<exclude-pattern>*/class-consent-log.php</exclude-pattern>
		<exclude-pattern>*/class-admin.php</exclude-pattern>
		<exclude-pattern>*/class-admin-page-*.php</exclude-pattern>
	</rule>

	<!-- NonceVerification in class-admin.php: VERIFICATO MANUALMENTE (rev. 3.3.0).
	     Gli handler che SALVANO dati — handle_save() e handle_create_policy_page()
	     — verificano il nonce con wp_verify_nonce() prima di processare, e i form
	     emettono wp_nonce_field(). Le righe segnalate sono invece letture di
	     parametri di sola visualizzazione ($_GET['dbcm_msg'] per i flash) e
	     chiamate di rendering, che non processano form. Falsi positivi: lo sniff
	     vede $_GET/$_POST fuori da un nonce nello stesso scope senza distinguere
	     lettura innocua da azione. NON riattivare senza verificare che TUTTI gli
	     handler di salvataggio mantengano il controllo nonce.
	     3.5.1: split meccanico in class-admin-page-*.php — gli handler che
	     salvano (handle_save, handle_create_policy_page, handle_*_signatures,
	     handle_bump_consent_version) verificano tutti il nonce; le letture
	     segnalate restano quelle di sola visualizzazione ($_GET filtri log,
	     parametro edit firme, dbcm_msg flash). Stessa verifica manuale. -->
	<rule ref="WordPress.Security.NonceVerification">
		<exclude-pattern>*/class-admin.php</exclude-pattern>
		<exclude-pattern>*/class-admin-page-*.php</exclude-pattern>
	</rule>

	<config name="testVersion" value="7.4-"/>
	<rule ref="PHPCompatibilityWP"/>
</ruleset>
